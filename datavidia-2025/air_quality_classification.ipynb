   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import lightgbm as lgb\n",
    "import optuna\n",
    "import random\n",
    "import os\n",
    "from sklearn.metrics import f1_score\n",
    "from sklearn.utils.class_weight import compute_sample_weight\n",
    "from tqdm.auto import tqdm  # <--- NEW: Progress Bar\n",
    "import warnings\n",
    "\n",
    "# --- 0. REPRODUCIBILITY SETUP ---\n",
    "SEED = 42\n",
    "\n",
    "def set_seed(seed=SEED):\n",
    "    random.seed(seed)\n",
    "    np.random.seed(seed)\n",
    "    os.environ['PYTHONHASHSEED'] = str(seed)\n",
    "\n",
    "set_seed(SEED)\n",
    "\n",
    "# Enable Optuna INFO logs to see Tuning ETA\n",
    "optuna.logging.set_verbosity(optuna.logging.INFO)\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# --- 1. Feature Engineering ---\n",
    "\n",
    "def create_cyclical_features(df, col_name, period):\n",
    "    df[f'{col_name}_sin'] = np.sin(2 * np.pi * df[col_name] / period)\n",
    "    df[f'{col_name}_cos'] = np.cos(2 * np.pi * df[col_name] / period)\n",
    "    return df\n",
    "\n",
    "def feature_engineering(df):\n",
    "    df['tanggal'] = pd.to_datetime(df['tanggal'])\n",
    "    \n",
    "    # Date Components\n",
    "    df['year'] = df['tanggal'].dt.year\n",
    "    df['month'] = df['tanggal'].dt.month\n",
    "    df['day_of_week'] = df['tanggal'].dt.dayofweek\n",
    "    df['day_of_year'] = df['tanggal'].dt.dayofyear\n",
    "    \n",
    "    # Cyclical Features\n",
    "    df = create_cyclical_features(df, 'day_of_week', 7)\n",
    "    df = create_cyclical_features(df, 'month', 12)\n",
    "    df = create_cyclical_features(df, 'day_of_year', 365)\n",
    "    \n",
    "    wd_col = 'wind_direction_10m_dominant (°)'\n",
    "    if wd_col in df.columns:\n",
    "        df[f'wind_dir_sin'] = np.sin(np.deg2rad(df[wd_col]))\n",
    "        df[f'wind_dir_cos'] = np.cos(np.deg2rad(df[wd_col]))\n",
    "        \n",
    "    return df\n",
    "\n",
    "def create_lags(df, target_col, lags, rolling_windows):\n",
    "    df = df.sort_values(['stasiun', 'tanggal'])\n",
    "    \n",
    "    for lag in lags:\n",
    "        df[f'lag_{lag}'] = df.groupby('stasiun')[target_col].shift(lag)\n",
    "        \n",
    "    for window in rolling_windows:\n",
    "        grouped = df.groupby('stasiun')[target_col].shift(1)\n",
    "        df[f'roll_mean_{window}'] = grouped.rolling(window).mean().reset_index(0, drop=True)\n",
    "        df[f'roll_std_{window}'] = grouped.rolling(window).std().reset_index(0, drop=True)\n",
    "        \n",
    "    return df\n",
    "\n",
    "# --- 2. Optuna Objective (Walk-Forward CV) ---\n",
    "\n",
    "def objective(trial, df, target_col, feature_cols, cv_years):\n",
    "    # Hyperparameters\n",
    "    params = {\n",
    "        'objective': 'multiclass',\n",
    "        'num_class': 3,\n",
    "        'metric': 'multi_logloss',\n",
    "        'verbosity': -1,\n",
    "        'boosting_type': 'gbdt',\n",
    "        'n_estimators': 3000, \n",
    "        'class_weight': 'balanced', \n",
    "        \n",
    "        # Reproducibility\n",
    "        'seed': SEED, 'feature_fraction_seed': SEED, 'bagging_seed': SEED, 'drop_seed': SEED, 'data_random_seed': SEED,\n",
    "        \n",
    "        # Tuning Ranges\n",
    "        'learning_rate': trial.suggest_float('learning_rate', 0.001, 0.05, log=True),\n",
    "        'num_leaves': trial.suggest_int('num_leaves', 20, 256),\n",
    "        'max_depth': trial.suggest_int('max_depth', 3, 12),\n",
    "        'min_child_samples': trial.suggest_int('min_child_samples', 20, 200),\n",
    "        'subsample': trial.suggest_float('subsample', 0.4, 0.9),\n",
    "        'colsample_bytree': trial.suggest_float('colsample_bytree', 0.4, 0.9),\n",
    "        'reg_alpha': trial.suggest_float('reg_alpha', 1e-4, 10.0, log=True),\n",
    "        'reg_lambda': trial.suggest_float('reg_lambda', 1e-4, 10.0, log=True),\n",
    "    }\n",
    "\n",
    "    f1_scores = []\n",
    "    \n",
    "    # Walk-Forward Validation Loop\n",
    "    for year in cv_years:\n",
    "        val_start = pd.Timestamp(f'{year}-09-01')\n",
    "        val_end = pd.Timestamp(f'{year}-11-30')\n",
    "        \n",
    "        train_mask = (df['tanggal'] < val_start)\n",
    "        val_mask = (df['tanggal'] >= val_start) & (df['tanggal'] <= val_end)\n",
    "        \n",
    "        if train_mask.sum() < 100 or val_mask.sum() < 10:\n",
    "            continue\n",
    "            \n",
    "        X_train = df.loc[train_mask, feature_cols]\n",
    "        y_train = df.loc[train_mask, target_col]\n",
    "        X_val = df.loc[val_mask, feature_cols]\n",
    "        y_val = df.loc[val_mask, target_col]\n",
    "        \n",
    "        dtrain = lgb.Dataset(X_train, label=y_train)\n",
    "        dval = lgb.Dataset(X_val, label=y_val, reference=dtrain)\n",
    "        \n",
    "        model = lgb.train(\n",
    "            params, dtrain, valid_sets=[dval],\n",
    "            callbacks=[lgb.early_stopping(stopping_rounds=100, verbose=False)]\n",
    "        )\n",
    "        \n",
    "        preds = np.argmax(model.predict(X_val), axis=1)\n",
    "        f1 = f1_score(y_val, preds, average='macro')\n",
    "        f1_scores.append(f1)\n",
    "    \n",
    "    return np.mean(f1_scores) if f1_scores else 0.0\n",
    "\n",
    "def tune_model(df, target_col, feature_cols, cv_years, n_trials=30, study_name=\"lgbm_study\"):\n",
    "    print(f\"\\n--- Tuning {study_name} ({n_trials} trials) ---\")\n",
    "    \n",
    "    sampler = optuna.samplers.TPESampler(seed=SEED)\n",
    "    study = optuna.create_study(direction='maximize', study_name=study_name, sampler=sampler)\n",
    "    \n",
    "    # Use Optuna's built-in progress bar\n",
    "    func = lambda trial: objective(trial, df, target_col, feature_cols, cv_years)\n",
    "    study.optimize(func, n_trials=n_trials, show_progress_bar=True) \n",
    "    \n",
    "    print(f\"Best Avg Macro F1: {study.best_value:.4f}\")\n",
    "    \n",
    "    best_params = study.best_params\n",
    "    best_params.update({\n",
    "        'objective': 'multiclass', 'num_class': 3, 'metric': 'multi_logloss',\n",
    "        'boosting_type': 'gbdt', 'verbosity': -1, 'n_estimators': 5000,\n",
    "        'class_weight': 'balanced',\n",
    "        'seed': SEED, 'feature_fraction_seed': SEED, 'bagging_seed': SEED, 'drop_seed': SEED, 'data_random_seed': SEED\n",
    "    })\n",
    "    return best_params\n",
    "\n",
    "# --- 3. Final Train & Forecast ---\n",
    "\n",
    "def run_pipeline(df, stations):\n",
    "    set_seed(SEED)\n",
    "    \n",
    "    # A. Data Prep\n",
    "    print(\"Step 1/5: Feature Engineering & Sanitization...\")\n",
    "    target_col = 'kategori'\n",
    "    df[target_col] = df[target_col].clip(upper=2).astype(int)\n",
    "    df = feature_engineering(df)\n",
    "    \n",
    "    exclude_cols = ['tanggal', 'stasiun', 'kategori', 'max', 'parameter_pencemar_kritis', 'year']\n",
    "    base_feats = [c for c in df.columns if c not in exclude_cols]\n",
    "\n",
    "    # B. Creating Datasets\n",
    "    print(\"Step 2/5: Creating Datasets (Calculating Lags)...\")\n",
    "    \n",
    "    # Recursive Data\n",
    "    df_rec = create_lags(df.copy(), target_col, lags=[1, 2, 3, 7, 14, 28], rolling_windows=[7, 30])\n",
    "    df_rec = df_rec.dropna(subset=[f'lag_28']) \n",
    "    rec_feats = base_feats + [c for c in df_rec.columns if 'lag_' in c or 'roll_' in c]\n",
    "    \n",
    "    # Direct Data (Yearly Lags)\n",
    "    df_dir = create_lags(df.copy(), target_col, lags=[360, 365, 370], rolling_windows=[30])\n",
    "    df_dir = df_dir.dropna(subset=[f'lag_370'])\n",
    "    dir_feats = base_feats + [c for c in df_dir.columns if 'lag_' in c or 'roll_' in c]\n",
    "\n",
    "    # C. Tuning\n",
    "    print(\"Step 3/5: Tuning Hyperparameters...\")\n",
    "    cv_years = [2021, 2022, 2023, 2024]\n",
    "    \n",
    "    best_params_rec = tune_model(df_rec, target_col, rec_feats, cv_years, n_trials=20, study_name=\"Recursive\")\n",
    "    best_params_dir = tune_model(df_dir, target_col, dir_feats, cv_years, n_trials=20, study_name=\"Direct\")\n",
    "\n",
    "    # D. Final Training\n",
    "    print(\"\\nStep 4/5: Final Training on Full History...\")\n",
    "    \n",
    "    print(\"  -> Training Recursive Model...\")\n",
    "    dtrain_rec = lgb.Dataset(df_rec[rec_feats], label=df_rec[target_col])\n",
    "    model_rec = lgb.train(best_params_rec, dtrain_rec, num_boost_round=best_params_rec['n_estimators'])\n",
    "    \n",
    "    print(\"  -> Training Direct Model...\")\n",
    "    dtrain_dir = lgb.Dataset(df_dir[dir_feats], label=df_dir[target_col])\n",
    "    model_dir = lgb.train(best_params_dir, dtrain_dir, num_boost_round=best_params_dir['n_estimators'])\n",
    "\n",
    "    # E. Forecasting\n",
    "    print(\"\\nStep 5/5: Ensemble Forecasting (2025)...\")\n",
    "    \n",
    "    future_dates = pd.date_range(start='2025-09-01', end='2025-11-30', freq='D')\n",
    "    submission_rows = []\n",
    "    weather_cols = [c for c in base_feats if c not in ['is_holiday_nasional', 'is_weekend', 'month', 'day_of_week', 'day_of_year'] and 'sin' not in c and 'cos' not in c]\n",
    "\n",
    "    # PROGRESS BAR 1: Stations\n",
    "    station_pbar = tqdm(stations, desc=\"Processing Stations\", unit=\"station\")\n",
    "    \n",
    "    for station in station_pbar:\n",
    "        st_data = df[df['stasiun'] == station].copy().sort_values('tanggal')\n",
    "        \n",
    "        future_df = pd.DataFrame({'tanggal': future_dates, 'stasiun': station})\n",
    "        future_df = feature_engineering(future_df)\n",
    "        \n",
    "        future_df['is_holiday_nasional'] = 0 \n",
    "        future_df['is_weekend'] = future_df['tanggal'].dt.dayofweek.isin([5, 6]).astype(int)\n",
    "        \n",
    "        full_st_df = pd.concat([st_data, future_df], ignore_index=True)\n",
    "        history_len = len(st_data)\n",
    "        \n",
    "        # Fill Future Weather\n",
    "        for i in range(history_len, len(full_st_df)):\n",
    "            curr_date = full_st_df.loc[i, 'tanggal']\n",
    "            past_date = curr_date - pd.DateOffset(years=1)\n",
    "            past_row = st_data[st_data['tanggal'].dt.date == past_date.date()]\n",
    "            if not past_row.empty:\n",
    "                full_st_df.loc[i, weather_cols] = past_row.iloc[0][weather_cols]\n",
    "            else:\n",
    "                full_st_df.loc[i, weather_cols] = full_st_df.loc[i-1, weather_cols]\n",
    "\n",
    "        # RECURSIVE LOOP\n",
    "        # PROGRESS BAR 2: Days (Nested, leave=False to clear after station done)\n",
    "        days_range = range(history_len, len(full_st_df))\n",
    "        for i in tqdm(days_range, desc=f\"Predicting {station}\", leave=False, unit=\"day\"):\n",
    "            \n",
    "            # Use larger window for yearly lags (400 days back)\n",
    "            window_subset = full_st_df.iloc[max(0, i-400):i+1].copy()\n",
    "            \n",
    "            # Rec Feats\n",
    "            tmp_rec = create_lags(window_subset, target_col, lags=[1, 2, 3, 7, 14, 28], rolling_windows=[7, 30])\n",
    "            row_rec = tmp_rec.iloc[[-1]][rec_feats]\n",
    "            \n",
    "            # Dir Feats\n",
    "            tmp_dir = create_lags(window_subset, target_col, lags=[360, 365, 370], rolling_windows=[30])\n",
    "            row_dir = tmp_dir.iloc[[-1]][dir_feats]\n",
    "            \n",
    "            # Predict\n",
    "            prob_rec = model_rec.predict(row_rec)[0] \n",
    "            prob_dir = model_dir.predict(row_dir)[0]\n",
    "            \n",
    "            final_probs = (0.5 * prob_rec) + (0.5 * prob_dir)\n",
    "            final_class = np.argmax(final_probs)\n",
    "            \n",
    "            full_st_df.loc[i, target_col] = final_class\n",
    "            \n",
    "            label_map = {0: \"BAIK\", 1: \"SEDANG\", 2: \"TIDAK SEHAT\"}\n",
    "            date_str = full_st_df.loc[i, 'tanggal'].strftime('%Y-%m-%d')\n",
    "            submission_rows.append({\n",
    "                'id': f\"{date_str}_DKI{station}\", \n",
    "                'category': label_map[final_class]\n",
    "            })\n",
    "    \n",
    "    station_pbar.close()\n",
    "    \n",
    "    sub_df = pd.DataFrame(submission_rows)\n",
    "    sub_df = sub_df.sort_values('id').reset_index(drop=True)\n",
    "    return sub_df\n",
    "\n",
    "# --- EXECUTION ---\n",
    "stations_list = final_df['stasiun'].unique()\n",
    "submission = run_pipeline(final_df, stations_list)\n",
    "print(submission.head())"
   ]
