    "## gemini"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 36,
   "id": "75bc4ed0-d42e-4ece-a632-18e9c786be78",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "1. Predicting Sep-Nov 2025 Weather using KNN...\n",
      "   Climate Twins: [np.int32(2024), np.int32(2016), np.int32(2017), np.int32(2020), np.int32(2022)]\n",
      "2. Training Classifier on Historical Weather Patterns...\n",
      "3. Forecasting using Synthetic Weather...\n",
      "\n",
      "Predicted Distribution:\n",
      "category\n",
      "SEDANG         0.747253\n",
      "TIDAK SEHAT    0.228571\n",
      "BAIK           0.024176\n",
      "Name: proportion, dtype: float64\n",
      "                id     category\n",
      "0  2025-09-01_DKI1  TIDAK SEHAT\n",
      "1  2025-09-01_DKI2       SEDANG\n",
      "2  2025-09-01_DKI3  TIDAK SEHAT\n",
      "3  2025-09-01_DKI4       SEDANG\n",
      "4  2025-09-01_DKI5       SEDANG\n"
     ]
    }
   ],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import lightgbm as lgb\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.neighbors import NearestNeighbors\n",
    "import warnings\n",
    "\n",
    "# --- CONFIG ---\n",
    "SEED = 42\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# --- 1. STAGE 1: PREDICT THE WEATHER (Using Climate Twins) ---\n",
    "def predict_2025_weather(df, target_year=2025):\n",
    "    print(\"1. Predicting Sep-Nov 2025 Weather using KNN...\")\n",
    "    df = df.copy()\n",
    "    df['tanggal'] = pd.to_datetime(df['tanggal'])\n",
    "    df['month'] = df['tanggal'].dt.month\n",
    "    \n",
    "    # A. Find Twin Years (Based on Jan-Aug Context)\n",
    "    # We use the 5 key meteorological features\n",
    "    cols = ['wind_speed_10m_max (km/h)', 'temperature_2m_mean (°C)', \n",
    "            'relative_humidity_2m_mean (%)', 'shortwave_radiation_sum (MJ/m²)', \n",
    "            'precipitation_sum (mm)']\n",
    "    \n",
    "    jan_aug = df[df['month'] <= 8].groupby(df['tanggal'].dt.year)[cols].mean()\n",
    "    \n",
    "    # Scale & Search\n",
    "    scaler = StandardScaler()\n",
    "    scaled = scaler.fit_transform(jan_aug)\n",
    "    knn = NearestNeighbors(n_neighbors=6, metric='euclidean')\n",
    "    knn.fit(scaled)\n",
    "    \n",
    "    if target_year not in jan_aug.index:\n",
    "        twin_years = [2024, 2022, 2021, 2016, 2010] # Fallback Wet Years\n",
    "    else:\n",
    "        target_vec = scaled[jan_aug.index.get_loc(target_year)].reshape(1, -1)\n",
    "        indices = knn.kneighbors(target_vec, return_distance=False)\n",
    "        twin_years = [jan_aug.index[i] for i in indices[0] if jan_aug.index[i] < target_year]\n",
    "        \n",
    "    print(f\"   Climate Twins: {twin_years}\")\n",
    "    \n",
    "    # B. Impute Daily Weather (The \"Prediction\")\n",
    "    # We take the average weather of the Twin Years for each day (Sep 1 - Nov 30)\n",
    "    history = df[\n",
    "        (df['tanggal'].dt.year.isin(twin_years)) & \n",
    "        (df['tanggal'].dt.month >= 9) & \n",
    "        (df['tanggal'].dt.month <= 11)\n",
    "    ].copy()\n",
    "    \n",
    "    history['doy'] = history['tanggal'].dt.dayofyear\n",
    "    \n",
    "    # Calculate Synthetic Weather per Station per Day\n",
    "    # This preserves local micro-climates (e.g., DKI1 is hotter than DKI5)\n",
    "    synthetic_weather = history.groupby(['stasiun', 'doy'])[cols].mean().reset_index()\n",
    "    \n",
    "    return synthetic_weather, cols\n",
    "\n",
    "# --- 2. STAGE 2: PREDICT THE CATEGORY (Using Predicted Weather) ---\n",
    "def run_weather_driven_pipeline(df, stations):\n",
    "    # A. Get Predicted Weather for 2025\n",
    "    syn_weather, weather_cols = predict_2025_weather(df)\n",
    "    \n",
    "    # B. Prepare Training Data\n",
    "    # We train on ALL history (not just twins) to learn the universal physics of pollution\n",
    "    print(\"2. Training Classifier on Historical Weather Patterns...\")\n",
    "    \n",
    "    df['tanggal'] = pd.to_datetime(df['tanggal'])\n",
    "    df['doy'] = df['tanggal'].dt.dayofyear\n",
    "    \n",
    "    # Filter valid data (Sep-Nov)\n",
    "    train_mask = (df['month'] >= 9) & (df['month'] <= 11) & (df['year'] < 2025) & (df['kategori'] != -1)\n",
    "    train_df = df[train_mask].copy()\n",
    "    \n",
    "    # Feature Engineering\n",
    "    train_df['doy_sin'] = np.sin(2 * np.pi * train_df['doy']/366)\n",
    "    train_df['doy_cos'] = np.cos(2 * np.pi * train_df['doy']/366)\n",
    "    \n",
    "    # Features = Predicted Weather + Seasonality + Identity\n",
    "    features = weather_cols + ['doy_sin', 'doy_cos', 'stasiun']\n",
    "    \n",
    "    X_train = train_df[features]\n",
    "    y_train = train_df['kategori']\n",
    "    \n",
    "    # LightGBM Classifier\n",
    "    model = lgb.LGBMClassifier(\n",
    "        n_estimators=1500, learning_rate=0.03, num_leaves=31,\n",
    "        class_weight='balanced', # Important to catch spikes even in wet years\n",
    "        random_state=SEED, verbose=-1\n",
    "    )\n",
    "    model.fit(X_train, y_train)\n",
    "    \n",
    "    # C. Forecast 2025\n",
    "    print(\"3. Forecasting using Synthetic Weather...\")\n",
    "    future_dates = pd.date_range('2025-09-01', '2025-11-30')\n",
    "    rows = []\n",
    "    \n",
    "    # Create lookup for fast access\n",
    "    weather_lookup = syn_weather.set_index(['stasiun', 'doy']).to_dict('index')\n",
    "    \n",
    "    for s in stations:\n",
    "        for d in future_dates:\n",
    "            doy = d.dayofyear\n",
    "            \n",
    "            # Fetch the PREDICTED weather for this day/station\n",
    "            # (If missing, fallback to global mean for safety)\n",
    "            w = weather_lookup.get((s, doy), {k:0 for k in weather_cols})\n",
    "            \n",
    "            row = {\n",
    "                'id': f\"{d.strftime('%Y-%m-%d')}_DKI{s}\",\n",
    "                'doy_sin': np.sin(2 * np.pi * doy/366),\n",
    "                'doy_cos': np.cos(2 * np.pi * doy/366),\n",
    "                'stasiun': s\n",
    "            }\n",
    "            # Add weather features\n",
    "            for k in weather_cols:\n",
    "                row[k] = w.get(k, 0)\n",
    "                \n",
    "            rows.append(row)\n",
    "            \n",
    "    test_df = pd.DataFrame(rows)\n",
    "    preds = model.predict(test_df[features])\n",
    "    \n",
    "    # Map back to labels\n",
    "    label_map = {0: \"BAIK\", 1: \"SEDANG\", 2: \"TIDAK SEHAT\"}\n",
    "    test_df['category'] = [label_map[c] for c in preds]\n",
    "    \n",
    "    print(\"\\nPredicted Distribution:\")\n",
    "    print(test_df['category'].value_counts(normalize=True))\n",
    "    \n",
    "    return test_df[['id', 'category']].sort_values('id').reset_index(drop=True)\n",
    "\n",
    "# --- EXECUTION ---\n",
    "stations_list = final_df['stasiun'].unique()\n",
    "submission = run_weather_driven_pipeline(final_df, stations_list)\n",
    "print(submission.head())"
   ]
  },
