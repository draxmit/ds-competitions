   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "# ==========================================\n",
    "# 1. CONFIGURATION\n",
    "# ==========================================\n",
    "STATION_MAP = {\n",
    "    'DKI1 (Bunderan HI)': 1, 'DKI1 Bunderan HI': 1,\n",
    "    'DKI2 (Kelapa Gading)': 2, 'DKI2 Kelapa Gading': 2,\n",
    "    'DKI3 (Jagakarsa)': 3, 'DKI3 Jagakarsa': 3,\n",
    "    'DKI4 (Lubang Buaya)': 4, 'DKI4 Lubang Buaya': 4,\n",
    "    'DKI5 (Kebon Jeruk)': 5, 'DKI5 Kebon Jeruk': 5\n",
    "}\n",
    "\n",
    "# Universal Column Map: Old/Weird Names -> Standard Names\n",
    "# We map EVERYTHING to the short standard: pm10, pm25, so2, co, o3, no2, max, kategori\n",
    "COL_NORMALIZER = {\n",
    "    # Old File Names\n",
    "    'pm_sepuluh': 'pm10',\n",
    "    'pm_duakomalima': 'pm25',\n",
    "    'sulfur_dioksida': 'so2',\n",
    "    'karbon_monoksida': 'co',\n",
    "    'ozon': 'o3',\n",
    "    'nitrogen_dioksida': 'no2',\n",
    "    \n",
    "    # New File Names (Just in case specific spelling differs)\n",
    "    'categori': 'kategori',\n",
    "    'critical': 'parameter_pencemar_kritis' \n",
    "}\n",
    "\n",
    "NUMERIC_COLS = ['pm10', 'pm25', 'so2', 'co', 'o3', 'no2', 'max']\n",
    "\n",
    "# ==========================================\n",
    "# 2. MAIN PROCESSING FUNCTION (HANDLES BOTH)\n",
    "# ==========================================\n",
    "\n",
    "def process_air_quality_data(df):\n",
    "    \"\"\"\n",
    "    Universal function to clean ANY version of the Jakarta Air Quality Dataset.\n",
    "    Detects format automatically -> Standardizes -> Fills Missing -> Returns Clean DF.\n",
    "    \"\"\"\n",
    "    print(\"🚀 Starting Data Processing...\")\n",
    "    \n",
    "    # --- STEP A: STANDARDIZE COLUMNS & DATES ---\n",
    "    print(\"   ↳ 🛠️ Detecting format and standardizing columns...\")\n",
    "    \n",
    "    # 1. Normalize Column Names (Rename 'pm_sepuluh' -> 'pm10', 'categori' -> 'kategori')\n",
    "    df = df.rename(columns=COL_NORMALIZER)\n",
    "    \n",
    "    # 2. Handle Date Parsing (The \"Smart\" Switch)\n",
    "    if 'periode_data' in df.columns:\n",
    "        # Case: Old Format (Split Columns)\n",
    "        print(\"     (Detected Old Format with 'periode_data')\")\n",
    "        year_month = df['periode_data'].astype(str)\n",
    "        day = df['tanggal'].astype(str).str.zfill(2)\n",
    "        full_date_str = year_month.str[:4] + '-' + year_month.str[4:6] + '-' + day\n",
    "        df['tanggal'] = pd.to_datetime(full_date_str, errors='coerce')\n",
    "    else:\n",
    "        # Case: New Format (Single Date Column)\n",
    "        print(\"     (Detected New Format with single 'tanggal')\")\n",
    "        df['tanggal'] = pd.to_datetime(df['tanggal'], errors='coerce')\n",
    "\n",
    "    # 3. Map Stations\n",
    "    df['stasiun'] = df['stasiun'].astype(str).str.strip().map(STATION_MAP)\n",
    "    \n",
    "    # 4. Map Categories (Handles both numeric and text inputs)\n",
    "    # 0=BAIK, 1=SEDANG, 2=TIDAK SEHAT, 3=SANGAT TIDAK SEHAT, 4=BERBAHAYA\n",
    "    cat_map = {\n",
    "        'BAIK': 0, 'SEDANG': 1, 'TIDAK SEHAT': 2, \n",
    "        'SANGAT TIDAK SEHAT': 2, 'BERBAHAYA': 2, 'TIDAK ADA DATA': 1\n",
    "    }\n",
    "    # Ensure it's string first, map it, fill unknowns with 1 (SEDANG)\n",
    "    df['kategori'] = df['kategori'].astype(str).str.upper().str.strip().map(cat_map).fillna(1).astype(int)\n",
    "\n",
    "    # 5. Final Filter\n",
    "    # Drop invalid rows\n",
    "    df = df.dropna(subset=['stasiun', 'tanggal'])\n",
    "    df['stasiun'] = df['stasiun'].astype(int)\n",
    "    \n",
    "    # Keep only standard columns\n",
    "    cols_to_keep = ['tanggal', 'stasiun', 'kategori'] + [c for c in NUMERIC_COLS if c in df.columns]\n",
    "    df_clean = df[cols_to_keep]\n",
    "\n",
    "    # --- STEP B: ITERATIVE FILLING (THE LOGIC) ---\n",
    "    print(\"   ↳ 🏗️ Filling missing values and creating missing stations...\")\n",
    "    all_stations = [1, 2, 3, 4, 5]\n",
    "    final_rows = []\n",
    "    \n",
    "    # Sort for processing\n",
    "    df_clean = df_clean.sort_values(by='tanggal')\n",
    "\n",
    "    for date, group in df_clean.groupby('tanggal'):\n",
    "        current_rows = group.to_dict('records')\n",
    "        \n",
    "        # 1. Fill NaNs in EXISTING rows (using daily mean)\n",
    "        temp_df = pd.DataFrame(current_rows)\n",
    "        for col in NUMERIC_COLS:\n",
    "            if col in temp_df.columns and not temp_df[col].isna().all():\n",
    "                day_mean = temp_df[col].mean()\n",
    "                for row in current_rows:\n",
    "                    if pd.isna(row.get(col)):\n",
    "                        row[col] = day_mean\n",
    "\n",
    "        # 2. Create MISSING stations (1-5)\n",
    "        existing_ids = group['stasiun'].unique()\n",
    "        missing_ids = sorted(list(set(all_stations) - set(existing_ids)))\n",
    "        \n",
    "        if missing_ids:\n",
    "            for station_id in missing_ids:\n",
    "                temp_df = pd.DataFrame(current_rows) # Refresh pool\n",
    "                new_row = {'tanggal': date, 'stasiun': station_id}\n",
    "                \n",
    "                # Fill features (Mean of pool)\n",
    "                means = temp_df[NUMERIC_COLS].mean()\n",
    "                for col in NUMERIC_COLS:\n",
    "                    new_row[col] = means.get(col, np.nan) # Safety .get\n",
    "                \n",
    "                # Fill Category (Mode of pool)\n",
    "                if 'kategori' in temp_df.columns:\n",
    "                    mode = temp_df['kategori'].mode()\n",
    "                    new_row['kategori'] = mode[0] if not mode.empty else 1\n",
    "                \n",
    "                current_rows.append(new_row)\n",
    "        \n",
    "        final_rows.extend(current_rows)\n",
    "\n",
    "    # --- STEP C: FINAL POLISH ---\n",
    "    print(\"   ↳ 🧹 Final Polish (Forward Fill for empty days)...\")\n",
    "    df_final = pd.DataFrame(final_rows)\n",
    "    # Sort: Date -> Station\n",
    "    df_final = df_final.sort_values(by=['tanggal', 'stasiun']).reset_index(drop=True)\n",
    "    \n",
    "    # Forward Fill -> Backward Fill (covers days where ALL stations were empty)\n",
    "    df_final = df_final.ffill().bfill()\n",
    "    \n",
    "    return df_final\n",
    "\n",
    "def check_grid_integrity(df):\n",
    "    \"\"\"\n",
    "    Validation Helper\n",
    "    \"\"\"\n",
    "    print(\"\\n--- 🔍 GRID INTEGRITY CHECK ---\")\n",
    "    n_dates = df['tanggal'].nunique()\n",
    "    n_stations = df['stasiun'].nunique()\n",
    "    expected = n_dates * 5\n",
    "    actual = len(df)\n",
    "    \n",
    "    print(f\"Dates: {n_dates} | Stations: {n_stations}\")\n",
    "    print(f\"Expected: {expected} | Actual: {actual}\")\n",
    "    \n",
    "    if expected == actual:\n",
    "        print(\"✅ STATUS: PERFECT GRID\")\n",
    "    else:\n",
    "        print(f\"❌ STATUS: MISMATCH (Diff: {expected - actual})\")\n",
    "\n",
    "new_df = pd.read_csv('full.csv', sep=';')\n",
    "new_df_clean = process_air_quality_data(new_df)\n",
    "check_grid_integrity(new_df_clean)\n",
    "new_df_clean.head()"
   ]
  },
