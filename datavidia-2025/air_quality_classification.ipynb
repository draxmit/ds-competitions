    "# rename to avoid collision\n",
    "gt = gt.rename(columns={\"category\": \"category_true\"})\n",
    "submission = submission.rename(columns={\"category\": \"category_pred\"})\n",
    "\n",
    "# merge on id\n",
    "df_eval = gt.merge(submission, on=\"id\", how=\"inner\")\n",
    "\n",
    "# compute macro F1\n",
    "macro_f1 = f1_score(\n",
    "    df_eval[\"category_true\"],\n",
    "    df_eval[\"category_pred\"],\n",
    "    average=\"macro\"\n",
    ")\n",
