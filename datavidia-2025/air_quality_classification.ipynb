   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import lightgbm as lgb\n",
    "import optuna\n",
    "import random\n",
    "import os\n",
    "from sklearn.metrics import f1_score\n",
    "from sklearn.utils.class_weight import compute_sample_weight\n",
    "import warnings\n",
    "\n",
    "# --- 0. REPRODUCIBILITY SETUP ---\n",
    "SEED = 42\n",
    "\n",
    "def set_seed(seed=SEED):\n",
    "    random.seed(seed)\n",
    "    np.random.seed(seed)\n",
    "    os.environ['PYTHONHASHSEED'] = str(seed)\n",
    "\n",
    "set_seed(SEED)\n",
    "\n",
    "# Suppress warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "optuna.logging.set_verbosity(optuna.logging.WARNING)\n",
    "\n",
    "# --- 1. Feature Engineering ---\n",
    "\n",
    "def create_cyclical_features(df, col_name, period):\n",
    "    df[f'{col_name}_sin'] = np.sin(2 * np.pi * df[col_name] / period)\n",
    "    df[f'{col_name}_cos'] = np.cos(2 * np.pi * df[col_name] / period)\n",
    "    return df\n",
    "\n",
    "def feature_engineering(df):\n",
    "    df['tanggal'] = pd.to_datetime(df['tanggal'])\n",
    "    \n",
    "    df['month'] = df['tanggal'].dt.month\n",
    "    df['day_of_week'] = df['tanggal'].dt.dayofweek\n",
    "    df['day_of_year'] = df['tanggal'].dt.dayofyear\n",
    "    \n",
    "    df = create_cyclical_features(df, 'day_of_week', 7)\n",
    "    df = create_cyclical_features(df, 'month', 12)\n",
    "    df = create_cyclical_features(df, 'day_of_year', 365)\n",
    "    \n",
    "    wd_col = 'wind_direction_10m_dominant (°)'\n",
    "    if wd_col in df.columns:\n",
    "        df[f'wind_dir_sin'] = np.sin(np.deg2rad(df[wd_col]))\n",
    "        df[f'wind_dir_cos'] = np.cos(np.deg2rad(df[wd_col]))\n",
    "        \n",
    "    return df\n",
    "\n",
    "def create_lags(df, target_col, lags, rolling_windows):\n",
    "    df = df.sort_values(['stasiun', 'tanggal'])\n",
    "    \n",
    "    for lag in lags:\n",
    "        df[f'lag_{lag}'] = df.groupby('stasiun')[target_col].shift(lag)\n",
    "        \n",
    "    for window in rolling_windows:\n",
    "        grouped = df.groupby('stasiun')[target_col].shift(1)\n",
    "        df[f'roll_mean_{window}'] = grouped.rolling(window).mean().reset_index(0, drop=True)\n",
    "        df[f'roll_std_{window}'] = grouped.rolling(window).std().reset_index(0, drop=True)\n",
    "        \n",
    "    return df\n",
    "\n",
    "# --- 2. Optuna Optimization (Weighted) ---\n",
    "\n",
    "def objective(trial, X_train, y_train, X_val, y_val, train_weights):\n",
    "    param_grid = {\n",
    "        'objective': 'multiclass',\n",
    "        'num_class': 3,  \n",
    "        'metric': 'multi_logloss',\n",
    "        'verbosity': -1,\n",
    "        'boosting_type': 'gbdt',\n",
    "        'n_estimators': 5000,\n",
    "        \n",
    "        # Reproducibility\n",
    "        'seed': SEED,\n",
    "        'feature_fraction_seed': SEED,\n",
    "        'bagging_seed': SEED,\n",
    "        'drop_seed': SEED,\n",
    "        'data_random_seed': SEED,\n",
    "        \n",
    "        # Tunable\n",
    "        'learning_rate': trial.suggest_float('learning_rate', 0.005, 0.1, log=True),\n",
    "        'num_leaves': trial.suggest_int('num_leaves', 20, 150),\n",
    "        'max_depth': trial.suggest_int('max_depth', -1, 15),\n",
    "        'min_child_samples': trial.suggest_int('min_child_samples', 10, 100),\n",
    "        'subsample': trial.suggest_float('subsample', 0.5, 1.0),\n",
    "        'colsample_bytree': trial.suggest_float('colsample_bytree', 0.5, 1.0),\n",
    "        'reg_alpha': trial.suggest_float('reg_alpha', 1e-8, 10.0, log=True),\n",
    "        'reg_lambda': trial.suggest_float('reg_lambda', 1e-8, 10.0, log=True),\n",
    "    }\n",
    "\n",
    "    # === APPLY WEIGHTS HERE ===\n",
    "    train_data = lgb.Dataset(X_train, label=y_train, weight=train_weights)\n",
    "    val_data = lgb.Dataset(X_val, label=y_val, reference=train_data)\n",
    "\n",
    "    my_callbacks = [lgb.early_stopping(stopping_rounds=50, verbose=False)]\n",
    "\n",
    "    model = lgb.train(\n",
    "        param_grid,\n",
    "        train_data,\n",
    "        valid_sets=[train_data, val_data], # Monitor both to see if learning happens\n",
    "        callbacks=my_callbacks\n",
    "    )\n",
    "    \n",
    "    preds_prob = model.predict(X_val)\n",
    "    preds_class = np.argmax(preds_prob, axis=1)\n",
    "    return f1_score(y_val, preds_class, average='macro')\n",
    "\n",
    "def tune_model(X_train, y_train, X_val, y_val, n_trials=20, study_name=\"lgbm_study\"):\n",
    "    print(f\"--- Tuning {study_name} ({n_trials} trials) ---\")\n",
    "    \n",
    "    # === CALCULATE CLASS WEIGHTS ===\n",
    "    # 'balanced' mode automatically adjusts weights inversely proportional to class frequencies\n",
    "    weights = compute_sample_weight(class_weight='balanced', y=y_train)\n",
    "    \n",
    "    sampler = optuna.samplers.TPESampler(seed=SEED)\n",
    "    study = optuna.create_study(direction='maximize', study_name=study_name, sampler=sampler)\n",
    "    \n",
    "    # Pass weights to objective\n",
    "    func = lambda trial: objective(trial, X_train, y_train, X_val, y_val, weights)\n",
    "    study.optimize(func, n_trials=n_trials)\n",
    "    \n",
    "    print(f\"Best Macro F1 for {study_name}: {study.best_value:.4f}\")\n",
    "    best_params = study.best_params\n",
    "    \n",
    "    best_params.update({\n",
    "        'objective': 'multiclass',\n",
    "        'num_class': 3,\n",
    "        'metric': 'multi_logloss',\n",
    "        'boosting_type': 'gbdt',\n",
    "        'verbosity': -1,\n",
    "        'n_estimators': 5000,\n",
    "        'seed': SEED,\n",
    "        'feature_fraction_seed': SEED,\n",
    "        'bagging_seed': SEED,\n",
    "        'drop_seed': SEED,\n",
    "        'data_random_seed': SEED\n",
    "    })\n",
    "    return best_params, weights\n",
    "\n",
    "# --- 3. Main Pipeline ---\n",
    "\n",
    "def train_final_model(X_train, y_train, X_val, y_val, params, weights):\n",
    "    # Apply weights to final training as well\n",
    "    train_data = lgb.Dataset(X_train, label=y_train, weight=weights)\n",
    "    val_data = lgb.Dataset(X_val, label=y_val, reference=train_data)\n",
    "    \n",
    "    model = lgb.train(\n",
    "        params,\n",
    "        train_data,\n",
    "        valid_sets=[train_data, val_data],\n",
    "        callbacks=[\n",
    "            lgb.early_stopping(stopping_rounds=50),\n",
    "            lgb.log_evaluation(period=100) # Print progress every 100 rounds\n",
    "        ]\n",
    "    )\n",
    "    return model\n",
    "\n",
    "def run_pipeline(df, stations):\n",
    "    set_seed(SEED)\n",
    "    \n",
    "    # --- A. Data Prep ---\n",
    "    print(\"Step 1: Feature Engineering & Sanitization...\")\n",
    "    target_col = 'kategori'\n",
    "    \n",
    "    # Force target to 0-2\n",
    "    df[target_col] = df[target_col].clip(upper=2).astype(int)\n",
    "    df = feature_engineering(df)\n",
    "    \n",
    "    train_cutoff = pd.Timestamp('2024-09-01')\n",
    "    val_end = pd.Timestamp('2024-11-30')\n",
    "    \n",
    "    exclude_cols = ['tanggal', 'stasiun', 'kategori', 'max', 'parameter_pencemar_kritis']\n",
    "    base_feats = [c for c in df.columns if c not in exclude_cols]\n",
    "\n",
    "    # --- B. Datasets ---\n",
    "    print(\"Step 2: Creating Datasets (Dropping NaNs)...\")\n",
    "    \n",
    "    # 1. Rec Data\n",
    "    df_rec = create_lags(df.copy(), target_col, lags=[1, 2, 3, 7, 14, 28], rolling_windows=[7, 30])\n",
    "    # IMPORTANT: Drop rows where lags are NaN (the first 30 days) to avoid confusing the model\n",
    "    df_rec = df_rec.dropna(subset=[f'lag_28', 'roll_mean_30']) \n",
    "    rec_feats = base_feats + [c for c in df_rec.columns if 'lag_' in c or 'roll_' in c]\n",
    "    \n",
    "    # 2. Dir Data\n",
    "    df_dir = create_lags(df.copy(), target_col, lags=[90, 91, 92, 98, 120], rolling_windows=[90])\n",
    "    # IMPORTANT: Drop rows where long lags are NaN (the first 120 days)\n",
    "    df_dir = df_dir.dropna(subset=[f'lag_120', 'roll_mean_90'])\n",
    "    dir_feats = base_feats + [c for c in df_dir.columns if 'lag_' in c or 'roll_' in c]\n",
    "\n",
    "    # Split Rec\n",
    "    X_train_rec = df_rec[df_rec['tanggal'] < train_cutoff][rec_feats]\n",
    "    y_train_rec = df_rec[df_rec['tanggal'] < train_cutoff][target_col]\n",
    "    X_val_rec = df_rec[(df_rec['tanggal'] >= train_cutoff) & (df_rec['tanggal'] <= val_end)][rec_feats]\n",
    "    y_val_rec = df_rec[(df_rec['tanggal'] >= train_cutoff) & (df_rec['tanggal'] <= val_end)][target_col]\n",
    "    \n",
    "    # Split Dir\n",
    "    X_train_dir = df_dir[df_dir['tanggal'] < train_cutoff][dir_feats]\n",
    "    y_train_dir = df_dir[df_dir['tanggal'] < train_cutoff][target_col]\n",
    "    X_val_dir = df_dir[(df_dir['tanggal'] >= train_cutoff) & (df_dir['tanggal'] <= val_end)][dir_feats]\n",
    "    y_val_dir = df_dir[(df_dir['tanggal'] >= train_cutoff) & (df_dir['tanggal'] <= val_end)][target_col]\n",
    "\n",
    "    # --- C. Tuning & Training (Weighted) ---\n",
    "    print(\"Step 3: Tuning with Optuna (Weighted for Imbalance)...\")\n",
    "    \n",
    "    best_params_rec, weights_rec = tune_model(X_train_rec, y_train_rec, X_val_rec, y_val_rec, n_trials=20, study_name=\"Recursive_Model\")\n",
    "    model_rec = train_final_model(X_train_rec, y_train_rec, X_val_rec, y_val_rec, best_params_rec, weights_rec)\n",
    "    \n",
    "    best_params_dir, weights_dir = tune_model(X_train_dir, y_train_dir, X_val_dir, y_val_dir, n_trials=20, study_name=\"Direct_Model\")\n",
    "    model_dir = train_final_model(X_train_dir, y_train_dir, X_val_dir, y_val_dir, best_params_dir, weights_dir)\n",
    "\n",
    "    # --- D. Forecast ---\n",
    "    print(\"Step 4: Ensemble Forecast...\")\n",
    "    \n",
    "    future_dates = pd.date_range(start='2025-09-01', end='2025-11-30', freq='D')\n",
    "    submission_rows = []\n",
    "    \n",
    "    weather_cols = [c for c in base_feats if c not in ['is_holiday_nasional', 'is_weekend', 'month', 'day_of_week', 'day_of_year'] and 'sin' not in c and 'cos' not in c]\n",
    "\n",
    "    for station in stations:\n",
    "        st_data = df[df['stasiun'] == station].copy().sort_values('tanggal')\n",
    "        \n",
    "        future_df = pd.DataFrame({'tanggal': future_dates, 'stasiun': station})\n",
    "        future_df = feature_engineering(future_df)\n",
    "        \n",
    "        future_df['is_holiday_nasional'] = 0 \n",
    "        future_df['is_weekend'] = future_df['tanggal'].dt.dayofweek.isin([5, 6]).astype(int)\n",
    "        \n",
    "        full_st_df = pd.concat([st_data, future_df], ignore_index=True)\n",
    "        history_len = len(st_data)\n",
    "        \n",
    "        # Fill Future Weather\n",
    "        for i in range(history_len, len(full_st_df)):\n",
    "            curr_date = full_st_df.loc[i, 'tanggal']\n",
    "            past_date = curr_date - pd.DateOffset(years=1)\n",
    "            past_row = st_data[st_data['tanggal'].dt.date == past_date.date()]\n",
    "            \n",
    "            if not past_row.empty:\n",
    "                full_st_df.loc[i, weather_cols] = past_row.iloc[0][weather_cols]\n",
    "            else:\n",
    "                full_st_df.loc[i, weather_cols] = full_st_df.loc[i-1, weather_cols]\n",
    "\n",
    "        # RECURSIVE LOOP\n",
    "        for i in range(history_len, len(full_st_df)):\n",
    "            window_subset = full_st_df.iloc[max(0, i-150):i+1].copy()\n",
    "            \n",
    "            tmp_rec = create_lags(window_subset, target_col, lags=[1, 2, 3, 7, 14, 28], rolling_windows=[7, 30])\n",
    "            row_rec = tmp_rec.iloc[[-1]][rec_feats]\n",
    "            \n",
    "            tmp_dir = create_lags(window_subset, target_col, lags=[90, 91, 92, 98, 120], rolling_windows=[90])\n",
    "            row_dir = tmp_dir.iloc[[-1]][dir_feats]\n",
    "            \n",
    "            prob_rec = model_rec.predict(row_rec)[0] \n",
    "            prob_dir = model_dir.predict(row_dir)[0]\n",
    "            \n",
    "            final_probs = (0.5 * prob_rec) + (0.5 * prob_dir)\n",
    "            final_class = np.argmax(final_probs)\n",
    "            \n",
    "            full_st_df.loc[i, target_col] = final_class\n",
    "            \n",
    "            label_map = {0: \"BAIK\", 1: \"SEDANG\", 2: \"TIDAK SEHAT\"}\n",
    "            final_label = label_map[final_class]\n",
    "            \n",
    "            date_str = full_st_df.loc[i, 'tanggal'].strftime('%Y-%m-%d')\n",
    "            submission_rows.append({\n",
    "                'id': f\"{date_str}_DKI{station}\", \n",
    "                'category': final_label\n",
    "            })\n",
    "    \n",
    "    sub_df = pd.DataFrame(submission_rows)\n",
    "    sub_df = sub_df.sort_values('id').reset_index(drop=True)\n",
    "    \n",
    "    return sub_df\n",
    "\n",
    "# --- EXECUTION ---\n",
    "stations_list = final_df['stasiun'].unique()\n",
    "submission = run_pipeline(final_df, stations_list)\n",
    "print(submission.head())"
   ]
  },
