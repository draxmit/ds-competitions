    "import pandas as pd\n",
    "import numpy as np\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.neighbors import NearestNeighbors\n",
    "import lightgbm as lgb\n",
    "import warnings\n",
    "\n",
    "# --- CONFIG ---\n",
    "SEED = 42\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# --- 1. DETECT METEOROLOGICAL TWINS (Strict Feature Selection) ---\n",
    "def find_climate_twins(df, target_year=2025):\n",
    "    print(f\"Analyzing Meteorological Patterns (Jan-Aug) to find twins for {target_year}...\")\n",
    "    \n",
    "    df = df.copy()\n",
    "    df['tanggal'] = pd.to_datetime(df['tanggal'])\n",
    "    df['year'] = df['tanggal'].dt.year\n",
    "    df['month'] = df['tanggal'].dt.month\n",
    "    \n",
    "    # 1. Filter Jan-Aug (Context Window)\n",
    "    jan_aug = df[df['month'] <= 8].copy()\n",
    "    \n",
    "    # 2. Aggregating ONLY the requested features\n",
    "    # We use Mean for continuous states and Sum for accumulation\n",
    "    yearly_stats = jan_aug.groupby('year').agg({\n",
    "        'wind_speed_10m_max (km/h)': 'mean',       # 1. Kecepatan Angin\n",
    "        'temperature_2m_mean (°C)': 'mean',        # 2. Temperatur Udara\n",
    "        'relative_humidity_2m_mean (%)': 'mean',   # 3. Kelembaban\n",
    "        'shortwave_radiation_sum (MJ/m²)': 'mean', # 4. Intensitas Matahari\n",
    "        'precipitation_sum (mm)': 'sum'            # 5. Curah Hujan\n",
    "    })\n",
    "    \n",
    "    # Rename columns for internal clarity\n",
    "    yearly_stats.columns = ['wind_speed', 'temp_mean', 'humidity', 'solar_radiation', 'rain_sum']\n",
    "    \n",
    "    print(\"   Feature Profile for 2025 (Jan-Aug):\")\n",
    "    if target_year in yearly_stats.index:\n",
    "        print(yearly_stats.loc[target_year])\n",
    "    \n",
    "    # 3. Normalize Data\n",
    "    scaler = StandardScaler()\n",
    "    scaled_stats = scaler.fit_transform(yearly_stats)\n",
    "    \n",
    "    # 4. Find Nearest Neighbors\n",
    "    knn = NearestNeighbors(n_neighbors=6, metric='euclidean')\n",
    "    knn.fit(scaled_stats)\n",
    "    \n",
    "    if target_year not in yearly_stats.index:\n",
    "        print(\"Error: 2025 data missing from Jan-Aug!\")\n",
    "        return []\n",
    "        \n",
    "    target_idx = yearly_stats.index.get_loc(target_year)\n",
    "    distances, indices = knn.kneighbors([scaled_stats[target_idx]])\n",
    "    \n",
    "    # Extract Twins\n",
    "    twin_years = []\n",
    "    print(\"\\nMeteorological Twins found:\")\n",
    "    \n",
    "    for i in range(1, len(indices[0])): # Skip self\n",
    "        idx = indices[0][i]\n",
    "        year = yearly_stats.index[idx]\n",
    "        dist = distances[0][i]\n",
    "        \n",
    "        if year < target_year:\n",
    "            twin_years.append(year)\n",
    "            # Show why it was picked (Rain is usually the dominant factor)\n",
    "            rain_val = yearly_stats.loc[year, 'rain_sum']\n",
    "            print(f\"  -> {year} (Dist: {dist:.4f}) | Rain: {rain_val:.0f}mm\")\n",
    "            \n",
    "    return twin_years\n",
    "\n",
    "# --- 2. CALCULATE ADAPTIVE RATIOS (Unchanged) ---\n",
    "def get_adaptive_ratios(df, twin_years):\n",
    "    print(f\"\\nCalculating Target Ratios based on Twins: {twin_years}\")\n",
    "    \n",
    "    history = df[\n",
    "        (df['tanggal'].dt.year.isin(twin_years)) & \n",
    "        (df['tanggal'].dt.month >= 9) & \n",
    "        (df['tanggal'].dt.month <= 11) &\n",
    "        (df['kategori'] != -1)\n",
    "    ]\n",
    "    \n",
    "    ratios = history['kategori'].value_counts(normalize=True).to_dict()\n",
    "    \n",
    "    # Safety Floors\n",
    "    ratios[2] = max(ratios.get(2, 0), 0.05)\n",
    "    ratios[0] = max(ratios.get(0, 0), 0.10)\n",
    "    ratios[1] = 1.0 - ratios[2] - ratios[0]\n",
    "    \n",
    "    print(f\"  -> Adaptive Ratios: {ratios}\")\n",
    "    return ratios, history\n",
    "\n",
    "# --- 3. DAY-SPECIFIC MODEL ---\n",
    "def run_adaptive_pipeline(df, stations):\n",
    "    # A. Detect Twins (Using ONLY Weather Features)\n",
    "    twin_years = find_climate_twins(df, target_year=2025)\n",
    "    \n",
    "    # B. Get Ratios & Training Data\n",
    "    target_ratios, training_data = get_adaptive_ratios(df, twin_years)\n",
    "    \n",
    "    print(\"Training Model on Meteorological Twins ONLY...\")\n",
    "    \n",
    "    training_data['day_of_year'] = training_data['tanggal'].dt.dayofyear\n",
    "    training_data['year_idx'] = training_data['tanggal'].dt.year - 2010\n",
    "    \n",
    "    # Features for Daily Prediction\n",
    "    # Note: We cannot use weather here because we don't have it for Sep-Nov 2025\n",
    "    X_train = training_data[['day_of_year', 'year_idx', 'stasiun']].copy()\n",
    "    X_train['doy_sin'] = np.sin(2 * np.pi * X_train['day_of_year']/366)\n",
    "    X_train['doy_cos'] = np.cos(2 * np.pi * X_train['day_of_year']/366)\n",
    "    \n",
    "    y_train = training_data['max']\n",
    "    \n",
    "    model = lgb.LGBMRegressor(\n",
    "        n_estimators=1000, learning_rate=0.05, num_leaves=31,\n",
    "        objective='regression_l1', random_state=SEED, verbose=-1\n",
    "    )\n",
    "    model.fit(X_train[['doy_sin', 'doy_cos', 'stasiun', 'year_idx']], y_train)\n",
    "    \n",
    "    # C. Forecast 2025\n",
    "    print(\"Forecasting 2025...\")\n",
    "    future_dates = pd.date_range('2025-09-01', '2025-11-30')\n",
    "    test_rows = []\n",
    "    \n",
    "    for s in stations:\n",
    "        for d in future_dates:\n",
    "            test_rows.append({\n",
    "                'id': f\"{d.strftime('%Y-%m-%d')}_DKI{s}\",\n",
    "                'doy_sin': np.sin(2 * np.pi * d.dayofyear/366),\n",
    "                'doy_cos': np.cos(2 * np.pi * d.dayofyear/366),\n",
    "                'stasiun': s,\n",
    "                'year_idx': 15 \n",
    "            })\n",
    "            \n",
    "    test_df = pd.DataFrame(test_rows)\n",
    "    preds_score = model.predict(test_df[['doy_sin', 'doy_cos', 'stasiun', 'year_idx']])\n",
    "    \n",
    "    # D. Force Distribution\n",
    "    print(\"Forcing Adaptive Distribution...\")\n",
    "    test_df['score'] = preds_score\n",
    "    test_df = test_df.sort_values('score')\n",
    "    \n",
    "    n = len(test_df)\n",
    "    final_cats = np.zeros(n, dtype=int)\n",
    "    \n",
    "    n_2 = int(n * target_ratios[2])\n",
    "    final_cats[-n_2:] = 2\n",
    "    \n",
    "    n_1 = int(n * target_ratios[1])\n",
    "    final_cats[-(n_2 + n_1) : -n_2] = 1\n",
    "    \n",
    "    label_map = {0: \"BAIK\", 1: \"SEDANG\", 2: \"TIDAK SEHAT\"}\n",
    "    test_df['category'] = [label_map[c] for c in final_cats]\n",
    "    \n",
    "    return test_df[['id', 'category']].sort_values('id').reset_index(drop=True)\n",
    "\n",
    "# --- EXECUTION ---\n",
    "stations_list = final_df['stasiun'].unique()\n",
    "submission = run_adaptive_pipeline(final_df, stations_list)\n",
    "submission.head()"
   ]
  },
