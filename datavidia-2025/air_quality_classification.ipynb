    "## BEST BY FAR: PICK SIMILAR YEARS (.2931)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "3ff0ff77-259a-4407-b8f0-1fddbd7d28e7",
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.neighbors import NearestNeighbors\n",
    "import lightgbm as lgb\n",
    "import warnings\n",
    "\n",
    "# --- CONFIG ---\n",
    "SEED = 42\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# --- 1. DETECT ANALOG YEARS (The \"No Cheat\" Logic) ---\n",
    "def find_climate_twins(df, target_year=2025):\n",
    "    print(f\"Analyzing Climate Patterns to find twins for {target_year}...\")\n",
    "    \n",
    "    df = df.copy()\n",
    "    df['tanggal'] = pd.to_datetime(df['tanggal'])\n",
    "    df['year'] = df['tanggal'].dt.year\n",
    "    df['month'] = df['tanggal'].dt.month\n",
    "    \n",
    "    # 1. Feature Engineering (Yearly Jan-Aug Stats)\n",
    "    # These are the signals available BEFORE Sep 1st\n",
    "    jan_aug = df[df['month'] <= 8].copy()\n",
    "    \n",
    "    # We aggregate by year to get the \"Climate Signature\"\n",
    "    yearly_stats = jan_aug.groupby('year').agg({\n",
    "        'precipitation_sum (mm)': 'sum',          # Wetness (La Nina proxy)\n",
    "        'pm_duakomalima': 'mean',                 # Background pollution\n",
    "        'temperature_2m_max (°C)': 'mean',        # Heat (El Nino proxy)\n",
    "        'kategori': lambda x: (x==2).mean()       # How toxic was the start of the year?\n",
    "    })\n",
    "    \n",
    "    # Rename for clarity\n",
    "    yearly_stats.columns = ['rain_sum', 'pm25_mean', 'temp_mean', 'toxic_ratio']\n",
    "    \n",
    "    # 2. Normalize Data (Rain is 10,000, PM2.5 is 60... need scaling)\n",
    "    scaler = StandardScaler()\n",
    "    scaled_stats = scaler.fit_transform(yearly_stats)\n",
    "    \n",
    "    # 3. Find Nearest Neighbors to 2025\n",
    "    # We want the 5 years that are most climatologically similar to 2025\n",
    "    knn = NearestNeighbors(n_neighbors=5, metric='euclidean') # 6 because 2025 includes itself\n",
    "    knn.fit(scaled_stats)\n",
    "    \n",
    "    # Get 2025 vector\n",
    "    if target_year not in yearly_stats.index:\n",
    "        print(\"Error: 2025 data missing from Jan-Aug!\")\n",
    "        return []\n",
    "        \n",
    "    target_idx = yearly_stats.index.get_loc(target_year)\n",
    "    distances, indices = knn.kneighbors([scaled_stats[target_idx]])\n",
    "    \n",
    "    # Extract the Years (excluding 2025 itself)\n",
    "    # indices[0] is the list of nearest row indices\n",
    "    twin_years = []\n",
    "    print(\"\\nClimate Twins for 2025 (Based on Jan-Aug):\")\n",
    "    \n",
    "    for i in range(1, len(indices[0])): # Skip 0 (self)\n",
    "        idx = indices[0][i]\n",
    "        year = yearly_stats.index[idx]\n",
    "        dist = distances[0][i]\n",
    "        \n",
    "        # We only accept twins if they are historically available (before 2025)\n",
    "        if year < target_year:\n",
    "            twin_years.append(year)\n",
    "            print(f\"  -> {year} (Distance: {dist:.4f}) | Rain: {yearly_stats.loc[year, 'rain_sum']:.0f}mm\")\n",
    "            \n",
    "    return twin_years\n",
    "\n",
    "# --- 2. CALCULATE ADAPTIVE RATIOS ---\n",
    "def get_adaptive_ratios(df, twin_years):\n",
    "    print(f\"\\nCalculating Target Ratios based on Twins: {twin_years}\")\n",
    "    \n",
    "    # We look at what happened in Sep-Nov of the Twin Years\n",
    "    history = df[\n",
    "        (df['tanggal'].dt.year.isin(twin_years)) & \n",
    "        (df['tanggal'].dt.month >= 9) & \n",
    "        (df['tanggal'].dt.month <= 11) &\n",
    "        (df['kategori'] != -1)\n",
    "    ]\n",
    "    \n",
    "    # Calculate distribution\n",
    "    ratios = history['kategori'].value_counts(normalize=True).to_dict()\n",
    "    \n",
    "    # Apply minimal safety floors (just in case twins were perfectly clean)\n",
    "    ratios[2] = max(ratios.get(2, 0), 0.05) # Min 5% Toxic (Safety)\n",
    "    ratios[0] = max(ratios.get(0, 0), 0.10) # Min 10% Good\n",
    "    ratios[1] = 1.0 - ratios[2] - ratios[0]\n",
    "    \n",
    "    print(f\"  -> Adaptive 'Clean Year' Ratios: {ratios}\")\n",
    "    return ratios, history\n",
    "\n",
    "# --- 3. DAY-SPECIFIC MODEL (With Adaptive Training) ---\n",
    "def run_adaptive_pipeline(df, stations):\n",
    "    # A. Detect Twins & Ratios\n",
    "    twin_years = find_climate_twins(df, target_year=2025)\n",
    "    target_ratios, training_data = get_adaptive_ratios(df, twin_years)\n",
    "    \n",
    "    # B. Train Model ONLY on Twin Years\n",
    "    # This prevents the model from learning \"Toxic\" patterns from years like 2015/2019\n",
    "    print(\"Training Model on Climate Twins ONLY...\")\n",
    "    \n",
    "    # Prepare Data (Day Specific Logic)\n",
    "    training_data['day_of_year'] = training_data['tanggal'].dt.dayofyear\n",
    "    training_data['year_idx'] = training_data['tanggal'].dt.year - 2010\n",
    "    \n",
    "    # Features\n",
    "    # Since we filter rows, we use simple features to map Day -> Pollution\n",
    "    # The \"trend\" is less relevant if we only pick specific years, so we focus on Seasonality\n",
    "    X_train = training_data[['day_of_year', 'year_idx', 'stasiun']].copy()\n",
    "    X_train['doy_sin'] = np.sin(2 * np.pi * X_train['day_of_year']/366)\n",
    "    X_train['doy_cos'] = np.cos(2 * np.pi * X_train['day_of_year']/366)\n",
    "    \n",
    "    # We predict the CONTINUOUS score ('max') to rank later\n",
    "    y_train = training_data['max']\n",
    "    \n",
    "    # LightGBM Regressor\n",
    "    model = lgb.LGBMRegressor(\n",
    "        n_estimators=1000, learning_rate=0.05, num_leaves=31,\n",
    "        objective='regression_l1', random_state=SEED, verbose=-1\n",
    "    )\n",
    "    model.fit(X_train[['doy_sin', 'doy_cos', 'stasiun', 'year_idx']], y_train)\n",
    "    \n",
    "    # C. Predict 2025\n",
    "    print(\"Forecasting 2025...\")\n",
    "    future_dates = pd.date_range('2025-09-01', '2025-11-30')\n",
    "    test_rows = []\n",
    "    \n",
    "    for s in stations:\n",
    "        for d in future_dates:\n",
    "            test_rows.append({\n",
    "                'id': f\"{d.strftime('%Y-%m-%d')}_DKI{s}\",\n",
    "                'doy_sin': np.sin(2 * np.pi * d.dayofyear/366),\n",
    "                'doy_cos': np.cos(2 * np.pi * d.dayofyear/366),\n",
    "                'stasiun': s,\n",
    "                'year_idx': 15 # 2025 - 2010\n",
    "            })\n",
    "            \n",
    "    test_df = pd.DataFrame(test_rows)\n",
    "    preds_score = model.predict(test_df[['doy_sin', 'doy_cos', 'stasiun', 'year_idx']])\n",
    "    \n",
    "    # D. Force Distribution (Using ADAPTIVE Ratios)\n",
    "    print(\"Forcing Adaptive Distribution...\")\n",
    "    \n",
    "    # Sort predictions\n",
    "    test_df['score'] = preds_score\n",
    "    test_df = test_df.sort_values('score')\n",
    "    \n",
    "    n = len(test_df)\n",
    "    final_cats = np.zeros(n, dtype=int)\n",
    "    \n",
    "    # Force Class 2 (Toxic)\n",
    "    n_2 = int(n * target_ratios[2])\n",
    "    final_cats[-n_2:] = 2 # Highest scores\n",
    "    \n",
    "    # Force Class 1 (Moderate)\n",
    "    n_1 = int(n * target_ratios[1])\n",
    "    final_cats[-(n_2 + n_1) : -n_2] = 1 # Middle scores\n",
    "    \n",
    "    # Remainder is Class 0 (Good)\n",
    "    \n",
    "    # Map\n",
    "    label_map = {0: \"BAIK\", 1: \"SEDANG\", 2: \"TIDAK SEHAT\"}\n",
    "    test_df['category'] = [label_map[c] for c in final_cats]\n",
    "    \n",
    "    return test_df[['id', 'category']].sort_values('id').reset_index(drop=True)\n",
    "\n",
    "# --- EXECUTION ---\n",
    "stations_list = final_df['stasiun'].unique()\n",
    "submission = run_adaptive_pipeline(final_df, stations_list)\n",
    "print(submission.head())\n",
    "print(submission['category'].value_counts(normalize=True))"
   ]
  },
