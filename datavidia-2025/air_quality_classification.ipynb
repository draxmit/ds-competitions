    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "def fill_missing_stations_and_dates(main_df, ref_df):\n",
    "    \"\"\"\n",
    "    1. Fills MISSING DATES (Holes) in the range.\n",
    "    2. Fills MISSING STATIONS (Partial days).\n",
    "    3. Fetches data from ref_df where possible.\n",
    "    4. Interpolates neighbors for missing numeric data.\n",
    "    5. Defaults categorical/flags (like is_holiday) to 0.\n",
    "    \"\"\"\n",
    "    print(\"🚀 Starting Complete Grid Reconstruction...\")\n",
    "    \n",
    "    # 1. Setup & Standardization\n",
    "    main_df['tanggal'] = pd.to_datetime(main_df['tanggal'])\n",
    "    ref_df['tanggal'] = pd.to_datetime(ref_df['tanggal'])\n",
    "    \n",
    "    all_stations = [1, 2, 3, 4, 5]\n",
    "    \n",
    "    # Map for Air Quality Columns\n",
    "    aq_map = {\n",
    "        'pm10': 'pm_sepuluh',\n",
    "        'pm25': 'pm_duakomalima',\n",
    "        'so2': 'sulfur_dioksida',\n",
    "        'co': 'karbon_monoksida',\n",
    "        'o3': 'ozon',\n",
    "        'no2': 'nitrogen_dioksida',\n",
    "        'max': 'max',\n",
    "        'kategori': 'kategori'\n",
    "    }\n",
    "    \n",
    "    # Categorical / Default-0 Columns\n",
    "    # We force these to 0 if the date is brand new and not in reference\n",
    "    default_zero_cols = [\n",
    "        'is_holiday_nasional', 'is_weekend', 'wind_direction_10m_dominant (°)',\n",
    "        'winddirection_10m_dominant (°)'\n",
    "    ]\n",
    "    \n",
    "    # Columns that are \"Day Constant\" (Weather) - used for partial day filling\n",
    "    day_constant_cols = [\n",
    "        'temperature_2m_max (°C)', 'temperature_2m_min (°C)', 'precipitation_sum (mm)',\n",
    "        'precipitation_hours (h)', 'wind_speed_10m_max (km/h)', 'shortwave_radiation_sum (MJ/m²)', \n",
    "        'temperature_2m_mean (°C)', 'relative_humidity_2m_mean (%)', 'cloud_cover_mean (%)', \n",
    "        'surface_pressure_mean (hPa)', 'wind_gusts_10m_max (km/h)', 'relative_humidity_2m_max (%)', \n",
    "        'relative_humidity_2m_min (%)', 'cloud_cover_max (%)', 'cloud_cover_min (%)', \n",
    "        'wind_gusts_10m_mean (km/h)', 'wind_speed_10m_mean (km/h)', 'wind_gusts_10m_min (km/h)', \n",
    "        'wind_speed_10m_min (km/h)', 'surface_pressure_max (hPa)', 'surface_pressure_min (hPa)', 'ndvi'\n",
    "    ] + default_zero_cols\n",
    "\n",
    "    # Prepare Reference Lookup\n",
    "    print(\"   ↳ 📚 Indexing reference dataframe...\")\n",
    "    ref_df = ref_df.drop_duplicates(subset=['tanggal', 'stasiun'])\n",
    "    ref_lookup = ref_df.set_index(['tanggal', 'stasiun']).to_dict('index')\n",
    "\n",
    "    # ==========================================\n",
    "    # STEP A: FILL MISSING DATE HOLES\n",
    "    # ==========================================\n",
    "    print(\"   ↳ 📅 Filling completely missing dates...\")\n",
    "    min_date = main_df['tanggal'].min()\n",
    "    max_date = main_df['tanggal'].max()\n",
    "    full_date_range = pd.date_range(start=min_date, end=max_date, freq='D')\n",
    "    existing_dates = pd.to_datetime(main_df['tanggal'].unique())\n",
    "    missing_dates = full_date_range.difference(existing_dates)\n",
    "    \n",
    "    date_hole_rows = []\n",
    "    \n",
    "    if len(missing_dates) > 0:\n",
    "        print(f\"     Found {len(missing_dates)} missing days. Creating empty templates...\")\n",
    "        for date in missing_dates:\n",
    "            for station_id in all_stations:\n",
    "                new_row = {'tanggal': date, 'stasiun': station_id}\n",
    "                \n",
    "                # 1. Try Fetch from Reference\n",
    "                ref_key = (date, station_id)\n",
    "                if ref_key in ref_lookup:\n",
    "                    ref_row = ref_lookup[ref_key]\n",
    "                    for ref_col, main_col in aq_map.items():\n",
    "                        if ref_col in ref_row:\n",
    "                            new_row[main_col] = ref_row[ref_col]\n",
    "                \n",
    "                # 2. Set defaults for flags (Safe assumption: Not a holiday if unknown)\n",
    "                for col in default_zero_cols:\n",
    "                    if col in main_df.columns:\n",
    "                        new_row[col] = 0\n",
    "                \n",
    "                date_hole_rows.append(new_row)\n",
    "        \n",
    "        # Add the new (mostly empty) rows to the dataframe so they can be interpolated\n",
    "        hole_df = pd.DataFrame(date_hole_rows)\n",
    "        main_df = pd.concat([main_df, hole_df], ignore_index=True)\n",
    "        main_df = main_df.sort_values(by=['tanggal', 'stasiun']).reset_index(drop=True)\n",
    "        \n",
    "        # 3. INTERPOLATE the newly added rows (Mean of neighbors)\n",
    "        # We only interpolate numeric columns to fill the gaps we just created\n",
    "        print(\"     Interpolating values for new dates (Mean of neighbors)...\")\n",
    "        numeric_cols = main_df.select_dtypes(include=[np.number]).columns.tolist()\n",
    "        numeric_cols = [c for c in numeric_cols if c != 'stasiun']\n",
    "        \n",
    "        # Group by station to ensure Station 1 interpolates from Station 1's neighbors\n",
    "        main_df[numeric_cols] = main_df.groupby('stasiun')[numeric_cols].transform(\n",
    "            lambda x: x.interpolate(method='linear', limit_direction='both')\n",
    "        )\n",
    "\n",
    "    # ==========================================\n",
    "    # STEP B: FILL MISSING STATIONS (PARTIAL DAYS)\n",
    "    # ==========================================\n",
    "    print(\"   ↳ 🏗️ Filling missing stations in partial days...\")\n",
    "    new_station_rows = []\n",
    "    unique_dates = main_df['tanggal'].unique()\n",
    "    \n",
    "    for date in unique_dates:\n",
    "        day_data = main_df[main_df['tanggal'] == date]\n",
    "        existing_stations = day_data['stasiun'].unique()\n",
    "        \n",
    "        # Determine missing stations\n",
    "        missing_stations = [s for s in all_stations if s not in existing_stations]\n",
    "        \n",
    "        if not missing_stations:\n",
    "            continue\n",
    "            \n",
    "        # Context for the day (Weather/Holidays) -> Take Mode/Mean from siblings\n",
    "        day_context = {}\n",
    "        for col in day_constant_cols:\n",
    "            if col in main_df.columns:\n",
    "                if col in default_zero_cols: \n",
    "                    mode_val = day_data[col].mode()\n",
    "                    day_context[col] = mode_val[0] if not mode_val.empty else 0\n",
    "                else: \n",
    "                    day_context[col] = day_data[col].mean()\n",
    "\n",
    "        for station_id in missing_stations:\n",
    "            new_row = {'tanggal': date, 'stasiun': station_id}\n",
    "            \n",
    "            # Fetch Reference\n",
    "            ref_key = (date, station_id)\n",
    "            if ref_key in ref_lookup:\n",
    "                ref_row = ref_lookup[ref_key]\n",
    "                for ref_col, main_col in aq_map.items():\n",
    "                    if ref_col in ref_row:\n",
    "                        new_row[main_col] = ref_row[ref_col]\n",
    "            \n",
    "            # Apply Day Context\n",
    "            new_row.update(day_context)\n",
    "            new_station_rows.append(new_row)\n",
    "    \n",
    "    if new_station_rows:\n",
    "        print(f\"     Adding {len(new_station_rows)} station rows...\")\n",
    "        new_station_df = pd.DataFrame(new_station_rows)\n",
    "        main_df = pd.concat([main_df, new_station_df], ignore_index=True)\n",
    "\n",
    "    # ==========================================\n",
    "    # STEP C: FINAL CLEANUP\n",
    "    # ==========================================\n",
    "    print(\"   ↳ 🧹 Final Polish...\")\n",
    "    main_df = main_df.sort_values(by=['tanggal', 'stasiun']).reset_index(drop=True)\n",
    "    \n",
    "    # Ensure any lingering NaNs (created in Step B) are filled with Daily Mean\n",
    "    numeric_cols = main_df.select_dtypes(include=[np.number]).columns.tolist()\n",
    "    numeric_cols = [c for c in numeric_cols if c != 'stasiun']\n",
    "    for col in numeric_cols:\n",
    "        main_df[col] = main_df[col].fillna(main_df.groupby('tanggal')[col].transform('mean'))\n",
    "    \n",
    "    # Final safety fill\n",
    "    main_df = main_df.ffill().bfill()\n",
    "    \n",
    "    # Drop duplicates\n",
    "    print(\"   ↳ ✂️ Removing duplicates...\")\n",
    "    main_df = main_df.drop_duplicates(subset=['tanggal', 'stasiun'], keep='first')\n",
    "\n",
    "    return main_df\n",
    "\n",
    "# ==========================================\n",
    "# EXECUTION\n",
    "# ==========================================\n",
    "# Run the complete reconstruction\n",
    "final_df = fill_missing_stations_and_dates(df, ispu_df_clean)\n",
    "\n",
    "# Final Checks\n",
    "print(\"\\n--- 🔍 FINAL INTEGRITY CHECK ---\")\n",
    "n_dates = final_df['tanggal'].nunique()\n",
    "n_stations = final_df['stasiun'].nunique()\n",
    "expected = n_dates * 5\n",
    "actual = len(final_df)\n",
    "\n",
    "print(f\"Dates: {n_dates} | Stations: {n_stations}\")\n",
    "print(f\"Expected: {expected} | Actual: {actual}\")\n",
    "\n",
    "# Check Date Continuity\n",
    "min_d = final_df['tanggal'].min()\n",
    "max_d = final_df['tanggal'].max()\n",
    "total_days = (max_d - min_d).days + 1\n",
    "\n",
    "if n_dates == total_days:\n",
    "    print(f\"✅ DATE CONTINUITY: PERFECT ({n_dates} days)\")\n",
    "else:\n",
    "    print(f\"❌ DATE CONTINUITY: MISSING {total_days - n_dates} DAYS\")\n",
    "\n",
    "if expected == actual:\n",
    "    print(\"✅ GRID: PERFECT\")\n",
    "else:\n",
    "    print(f\"❌ GRID: MISMATCH ({expected - actual})\")"
   ]
